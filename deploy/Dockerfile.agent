# Vulnbox agent image: the ipcap binary on top of the official eCapture image, so
# the whole agent (capture + listen + tls) deploys as a compose stack with nothing
# to install on the host. eCapture's release binary is fully static (pure-Go,
# CGO-free), which is why gojue/ecapture is Alpine-based — so we layer onto it
# directly instead of fetching the release and carrying a glibc base.
#
# Cross-compile ipcap on the native build platform (CGO-free), targeting
# TARGETARCH, so multi-arch builds never pay for slow QEMU emulation of the Go
# toolchain.
FROM --platform=$BUILDPLATFORM golang:1.24-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION=dev
ARG TARGETARCH
RUN CGO_ENABLED=0 GOARCH=$TARGETARCH go build -trimpath \
    -ldflags "-X main.version=${VERSION} -s -w" \
    -o /ipcap ./cmd/ipcap

# Pinned, multi-arch (amd64+arm64) official eCapture image — Alpine-based, ships
# the static eCapture at /ecapture. It tracks upstream, which MadrHacks/ecapture
# follows; bump the tag when the fork ships its own release.
FROM gojue/ecapture:v2.4.0
COPY --from=build /ipcap /usr/local/bin/ipcap
# eCapture lives at /ecapture in the base; expose it where the agent expects it.
RUN ln -sf /ecapture /usr/local/bin/ecapture
ENTRYPOINT ["/usr/local/bin/ipcap"]
